<html>

<head>
    <title>
        <%= title %>
    </title>
</head>

<body>
    <h1>
        <%= title %>
    </h1>
    <%- include("partials/searchUser.ejs") %>
    <% if(locals.searchResult){ %>
        <% if(userType === 'user'){ %>
            <p>
                ID: <%= searchResult.id %>, Name: <%= searchResult.firstName %>
                            <%= searchResult.lastName %>
                    <a href="/<%= searchResult.id %>/update">Update</a>

                    <form action="/<%= searchResult.id %>/delete" method="POST" style="display: inline;">
                        <button type="submit" onclick="return confirm('Are you sure you want to delete this user?');">Delete</button>
                    </form>
            </p>
        <% }else { %>
            <p>
                ID: <%= searchResult.id %>, Name: <%= searchResult.name %>, Email: <%= searchResult.email %>
                <a href="/<%= searchResult.id %>/updateEmail">Update</a>

                <form action="/<%= searchResult.id %>/deleteEmail" method="POST" style="display: inline;">
                    <button type="submit" onclick="return confirm('Are you sure you want to delete this email user?');">Delete</button>
                </form>
            </p>
            <a href="/">Back to home</a>
        <% } %>
    <% } %>
    <ul>
        <% if (locals.users) { %>
            <% users.forEach(user=> { %>
                <li>
                    ID: <%= user.id %>, Name: <%= user.firstName %>
                            <%= user.lastName %>
                    <a href="/<%= user.id %>/update">Update</a>

                    <form action="/<%= user.id %>/delete" method="POST" style="display: inline;">
                        <button type="submit" onclick="return confirm('Are you sure you want to delete this user?');">Delete</button>
                    </form>
                </li>
            <% }) %>
        <% } %>
        <a href="/create">Create a user</a>
        <% if(locals.emailUsers) { %>
            <% emailUsers.forEach( user => { %>
            <li>
                ID: <%= user.id %>, Name: <%= user.name %>, Email: <%= user.email %>
                <a href="/<%= user.id %>/updateEmail">Update</a>

                <form action="/<%= user.id %>/deleteEmail" method="POST" style="display: inline;">
                    <button type="submit" onclick="return confirm('Are you sure you want to delete this email user?');">Delete</button>
                </form>
            </li>
            <% }) %>
        <% } %>
        <a href="/createEmail">Create an email user</a>
    </ul>
</body>

</html>